<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>FoodTruck Owner – Menu Management</title>

    <!-- Bootstrap 3 CSS -->
    <link rel="stylesheet" href="/styles/bootstrap.min.css" />
    <link rel="stylesheet" href="/styles/style.css" />
    <style>
        :root {
            --brand: #f46b2a;
            --nav: #1f2a3b;
            --bg2: #6f6be8;
            --bg3: #7a4cc9;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(180deg, #25324a 0%, var(--bg2) 38%, var(--bg3) 100%);
            padding-bottom: 40px;
        }

        /* Navbar */
        .navbar-inverse {
            background: var(--nav);
            border: 0;
            border-bottom: 1px solid rgba(255, 255, 255, .08);
            border-radius: 0;
            margin-bottom: 0;
        }

        .navbar-inverse .navbar-brand,
        .navbar-inverse .navbar-nav>li>a {
            color: #fff;
        }

        .navbar-inverse .navbar-nav>li>a:hover {
            color: #fff;
            opacity: .9;
        }

        .navbar-inverse .navbar-nav>li.active>a {
            background: rgba(255, 255, 255, .1) !important;
        }

        /* Header band */
        .hero {
            background: rgba(31, 42, 59, .55);
            border-bottom: 1px solid rgba(255, 255, 255, .08);
            padding: 22px 0 18px;
            text-align: center;
            color: #fff;
        }

        .hero .title {
            font-weight: 800;
            font-size: 16px;
        }

        .hero .subtitle {
            opacity: .75;
            font-size: 12px;
            margin-top: 4px;
        }

        /* Main white panel */
        .panel-card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, .22);
            padding: 16px;
            margin: 25px auto 0;
            max-width: 980px;
        }

        .panel-top {
            overflow: hidden;
            margin-bottom: 10px;
        }

        .panel-top .left-title {
            float: left;
            font-weight: 700;
            color: #555;
            font-size: 12px;
            margin-top: 7px;
        }

        .panel-top .right-actions {
            float: right;
        }

        .btn-brand {
            background: var(--brand);
            border-color: var(--brand);
            color: #fff;
            font-weight: 700;
            letter-spacing: .2px;
        }

        .btn-brand:hover,
        .btn-brand:focus {
            background: var(--brand);
            border-color: var(--brand);
            color: #fff;
            filter: brightness(.95);
        }

        /* Table styling */
        .table {
            margin-bottom: 0;
        }

        .table>thead>tr>th {
            font-size: 12px;
            color: #777;
            border-bottom: 1px solid #eee;
        }

        .table>tbody>tr>td {
            vertical-align: middle;
            font-size: 12px;
        }

        .label-soft {
            background: #eaf7ea;
            color: #2f7d32;
            border: 1px solid rgba(47, 125, 50, .25);
            padding: 2px 8px;
            border-radius: 10px;
            font-weight: 700;
            display: inline-block;
            font-size: 11px;
        }

        .label-unavailable {
            background: #ffebee;
            color: #c62828;
            border: 1px solid rgba(198, 40, 40, .25);
            padding: 2px 8px;
            border-radius: 10px;
            font-weight: 700;
            display: inline-block;
            font-size: 11px;
        }

        .price {
            color: #b64619;
            font-weight: 800;
        }

        .btn-mini {
            padding: 3px 8px;
            font-size: 11px;
            border-radius: 4px;
        }

        .btn-blue {
            background: #2d7ff9;
            border-color: #2d7ff9;
            color: #fff;
        }

        .btn-blue:hover,
        .btn-blue:focus {
            color: #fff;
            opacity: .95;
        }

        .btn-orange {
            background: var(--brand);
            border-color: var(--brand);
            color: #fff;
        }

        .btn-orange:hover,
        .btn-orange:focus {
            color: #fff;
            opacity: .95;
        }

        .btn-red {
            background: #d9534f;
            border-color: #d9534f;
            color: #fff;
        }

        .btn-red:hover,
        .btn-red:focus {
            color: #fff;
            opacity: .95;
        }

        .actions .btn {
            margin-right: 4px;
        }

        .actions .btn:last-child {
            margin-right: 0;
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #999;
        }

        .empty-state .icon {
            font-size: 48px;
            margin-bottom: 15px;
            opacity: 0.5;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-inverse">
        <div class="container">
            <div class="navbar-header">
                <a class="navbar-brand" href="/dashboard">🍔 FoodTruck Owner</a>
            </div>

            <ul class="nav navbar-nav">
                <li><a href="/dashboard">Dashboard</a></li>
                <li class="active"><a href="/menuItems">Menu Items</a></li>
                <li><a href="/truckOrders">Orders</a></li>
            </ul>

            <ul class="nav navbar-nav navbar-right">
                <li><a href="/">Logout</a></li>
            </ul>
        </div>
    </nav>

    <!-- Header band -->
    <div class="hero">
        <div class="container">
            <div class="title">🍽️ Menu Management</div>
            <div class="subtitle">Manage your truck's menu items</div>
        </div>
    </div>

    <!-- White panel -->
    <div class="container">
        <div class="panel-card">
            <!-- Alert Messages -->
            <div id="menuAlert" class="alert alert-danger" style="display: none; margin-bottom: 15px;"></div>
            <div id="menuSuccess" class="alert alert-success" style="display: none; margin-bottom: 15px;"></div>

            <div class="panel-top">
                <div class="left-title">Your Menu Items</div>
                <div class="right-actions">
                    <button class="btn btn-brand btn-xs" id="btnAddNewItem">+ ADD NEW ITEM</button>
                </div>
            </div>

            <!-- Loading State -->
            <div id="loadingState" style="text-align: center; padding: 40px; display: none;">
                <p>Loading menu items...</p>
            </div>

            <!-- Empty State -->
            <div id="emptyState" class="empty-state" style="display: none;">
                <div class="icon">🍽️</div>
                <h4>No Menu Items Yet</h4>
                <p>Start by adding your first menu item</p>
            </div>

            <!-- Table -->
            <div class="table-responsive" id="menuTable" style="display: none;">
                <table class="table table-condensed">
                    <thead>
                        <tr>
                            <th style="width:60px;">ID</th>
                            <th style="width:140px;">Name</th>
                            <th style="width:110px;">Category</th>
                            <th>Description</th>
                            <th style="width:90px;">Price</th>
                            <th style="width:90px;">Status</th>
                            <th style="width:160px; text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="menuTableBody">
                        <!-- Items will be inserted here by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- View Item Modal -->
    <div class="modal fade" id="viewItemModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">Menu Item Details</h4>
                </div>
                <div class="modal-body" id="viewItemBody">
                    <!-- Details will be loaded here -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Item Modal -->
    <div class="modal fade" id="editItemModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">Edit Menu Item</h4>
                </div>
                <div class="modal-body">
                    <form id="editItemForm">
                        <input type="hidden" id="editItemId" />
                        <div class="form-group">
                            <label for="editName">Name</label>
                            <input type="text" class="form-control" id="editName" required />
                        </div>
                        <div class="form-group">
                            <label for="editCategory">Category</label>
                            <input type="text" class="form-control" id="editCategory" required />
                        </div>
                        <div class="form-group">
                            <label for="editDescription">Description</label>
                            <textarea class="form-control" id="editDescription" rows="3" required></textarea>
                        </div>
                        <div class="form-group">
                            <label for="editPrice">Price</label>
                            <input type="number" step="0.01" class="form-control" id="editPrice" required />
                        </div>
                        <div class="form-group">
                            <label for="editStatus">Status</label>
                            <select class="form-control" id="editStatus" required>
                                <option value="available">Available</option>
                                <option value="unavailable">Unavailable</option>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-brand" id="btnSaveEdit">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap 3 JS -->
    <script src="/js/jquery-2.2.0.min.js" type="text/javascript"></script>
    <script src="/js/bootstrap.min.js" type="text/javascript"></script>
    <script src="/src/menuItems.js" type="text/javascript"></script>
</body>

</html>