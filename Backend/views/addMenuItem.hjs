<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>FoodTruck Owner – Add Menu Item</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap 3 CSS -->
    <link rel="stylesheet" href="/styles/bootstrap.min.css" />
    <link rel="stylesheet" href="/styles/style.css" />

    <style>
        :root {
            --brand: #f46b2a;
            --nav: #1f2a3b;
            --bg2: #6f6be8;
            --bg3: #7a4cc9;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(180deg, #25324a 0%, var(--bg2) 38%, var(--bg3) 100%);
            padding-bottom: 40px;
        }

        /* Navbar */
        .navbar-inverse {
            background: var(--nav);
            border: 0;
            border-radius: 0;
            margin-bottom: 0;
            border-bottom: 1px solid rgba(255, 255, 255, .08);
        }

        .navbar-inverse .navbar-brand,
        .navbar-inverse .navbar-nav>li>a {
            color: #fff;
        }

        .navbar-inverse .navbar-nav>li.active>a {
            background: rgba(255, 255, 255, .1) !important;
        }

        /* Header band */
        .hero {
            background: rgba(31, 42, 59, .55);
            border-bottom: 1px solid rgba(255, 255, 255, .08);
            padding: 22px 0 18px;
            color: #fff;
            text-align: center;
        }

        .hero .title {
            font-weight: 800;
            font-size: 16px;
        }

        .hero .subtitle {
            opacity: .75;
            font-size: 12px;
            margin-top: 4px;
        }

        /* White card */
        .form-card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, .22);
            padding: 22px 22px 18px;
            max-width: 420px;
            margin: 30px auto;
            text-align: center;
        }

        .form-card h4 {
            font-weight: 800;
            margin-bottom: 18px;
        }

        .form-group label {
            font-size: 12px;
            color: #777;
            float: left;
            font-weight: 600;
        }

        .btn-brand {
            background: var(--brand);
            border-color: var(--brand);
            color: #fff;
            font-weight: 800;
        }

        .btn-brand:hover,
        .btn-brand:focus {
            background: var(--brand);
            border-color: var(--brand);
            color: #fff;
            filter: brightness(.95);
        }

        .btn-cancel {
            background: #f5f5f5;
            border-color: #ddd;
            font-weight: 700;
            color: #555;
        }

        .btn-cancel:hover {
            background: #e8e8e8;
            color: #333;
        }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-inverse">
        <div class="container">
            <div class="navbar-header">
                <a class="navbar-brand" href="/dashboard">🍔 FoodTruck Owner</a>
            </div>

            <ul class="nav navbar-nav">
                <li><a href="/dashboard">Dashboard</a></li>
                <li class="active"><a href="/menuItems">Menu Items</a></li>
                <li><a href="/truckOrders">Orders</a></li>
            </ul>

            <ul class="nav navbar-nav navbar-right">
                <li><a href="/logout">Logout</a></li>
            </ul>
        </div>
    </nav>

    <!-- Header -->
    <div class="hero">
        <div class="container">
            <div class="title">➕ Add Menu Item</div>
            <div class="subtitle">Create a new item for your menu</div>
        </div>
    </div>

    <!-- Form Card -->
    <div class="container">
        <div class="form-card">
            <div style="font-size:26px;opacity:.6;margin-bottom:8px;">🍽️</div>
            <h4>New Menu Item</h4>

            <!-- Alert Messages -->
            <div id="addItemAlert" class="alert alert-danger" style="display: none; text-align: left;"></div>
            <div id="addItemSuccess" class="alert alert-success" style="display: none; text-align: left;"></div>

            <form id="addItemForm">
                <div class="form-group">
                    <label>Item Name *</label>
                    <input type="text" class="form-control" id="itemName" name="name" placeholder="e.g. Beef Burger"
                        required>
                </div>

                <div class="form-group">
                    <label>Category *</label>
                    <input type="text" class="form-control" id="itemCategory" name="category"
                        placeholder="e.g. Fastfood" required>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea class="form-control" id="itemDescription" name="description" rows="3"
                        placeholder="Short description"></textarea>
                </div>

                <div class="form-group">
                    <label>Price ($) *</label>
                    <input type="number" step="0.01" min="0" class="form-control" id="itemPrice" name="price"
                        placeholder="0.00" required>
                </div>

                <div class="form-group" style="margin-top:18px;">
                    <button type="submit" class="btn btn-brand btn-block" id="btnSubmit">
                        ➕ ADD MENU ITEM
                    </button>
                    <button type="button" class="btn btn-cancel btn-block" id="btnCancel">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Bootstrap 3 JS -->
    <script src="/js/jquery-2.2.0.min.js" type="text/javascript"></script>
    <script src="/js/bootstrap.min.js" type="text/javascript"></script>
    <script src="/src/addMenuItem.js" type="text/javascript"></script>
</body>

</html>