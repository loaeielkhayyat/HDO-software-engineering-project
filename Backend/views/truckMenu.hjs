<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>GIU Food Truck – Menu</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/styles/bootstrap.min.css" />
    <link rel="stylesheet" href="/styles/style.css" />
    <style>
      :root {
        --brand: #f6682b;
        --brand-soft: #ffe6da;
        --bg1: #2a344a;
        --bg2: #6f6be8;
        --bg3: #7a4cc9;
      }
      body {
        min-height: 100vh;
        background: linear-gradient(180deg, #25324a 0%, var(--bg2) 38%, var(--bg3) 100%);
      }
      .brand-nav {
        background: #1f2a3b;
        border-bottom: 1px solid rgba(255,255,255,.08);
        border-radius: 0;
        margin-bottom: 0;
      }
      .brand-nav .navbar-brand {
        color: #fff !important;
        font-weight: 600;
      }
      .brand-nav .navbar-nav > li > a {
        color: #fff !important;
      }
      .hero-title {
        color: #fff;
        text-align: center;
        padding: 28px 0 14px;
      }
      .hero-title h4 {
        font-weight: bold;
        margin-bottom: 5px;
      }
      .hero-title small {
        display: block;
        opacity: 0.75;
        font-weight: 500;
        margin-top: 4px;
        color: rgba(255,255,255,0.7);
        font-size: 0.92rem;
      }
      .panel {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 18px 40px rgba(0,0,0,.22);
        padding: 18px 18px 22px;
        margin-bottom: 30px;
      }
      .menu-card {
        border-radius: 8px;
        border: 1px solid rgba(0,0,0,.08);
        box-shadow: 0 8px 16px rgba(0,0,0,.06);
        overflow: hidden;
        position: relative;
        padding: 15px;
        margin-bottom: 15px;
        background: #fff;
      }
      .menu-card::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 5px;
        background: var(--brand);
        opacity: 0.85;
      }
      .badge-type {
        background: var(--brand-soft);
        color: #b64619;
        border: 1px solid rgba(244,107,42,.25);
        font-weight: 600;
        padding: 4px 8px;
        border-radius: 4px;
      }
      .btn-brand {
        background: var(--brand);
        border-color: var(--brand);
        color: #fff;
        font-weight: 700;
        letter-spacing: 0.2px;
      }
      .btn-brand:hover {
        background: #e55a1f;
        border-color: #e55a1f;
        color: #fff;
      }
      .price {
        color: #b64619;
        font-weight: 800;
        font-size: 18px;
      }
      .panel-top {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
      }
      .panel-top .left-actions {
        display: flex;
        gap: 10px;
        align-items: center;
      }
      .panel-top .right-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex: 1;
        justify-content: flex-end;
        min-width: 260px;
      }
      .quantity-input {
        width: 60px;
        text-align: center;
        margin: 0 5px;
      }
      .menu-item-name {
        font-weight: bold;
        font-size: 18px;
        margin-bottom: 5px;
      }
      .menu-item-desc {
        color: #666;
        font-size: 14px;
        margin-bottom: 10px;
      }
      #successMessage {
        display: none;
        margin-top: 15px;
      }
      #menuError {
        display: none;
        margin-top: 15px;
      }
      @media (max-width: 768px) {
        .panel-top {
          justify-content: center;
        }
        .panel-top .right-actions {
          justify-content: center;
          flex-direction: column;
          width: 100%;
        }
        .panel-top .right-actions .searchbar {
          width: 100%;
          max-width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <!-- Top navbar -->
    <nav class="navbar navbar-inverse brand-nav">
      <div class="container-fluid">
        <div class="navbar-header">
          <a class="navbar-brand" href="/dashboard">🍔 GIU FoodTruck</a>
        </div>
        <ul class="nav navbar-nav">
          <li><a href="/trucks">🚚 Trucks</a></li>
          <li>
            <a href="/cart">
              🛒 Cart <span class="badge" id="cartCount" style="background: #fff; color: #000;">0</span>
            </a>
          </li>
          <li><a href="/orders">📦 My Orders</a></li>
        </ul>
        <ul class="nav navbar-nav navbar-right">
          <li><a href="/logout">Logout</a></li>
        </ul>
      </div>
    </nav>

    <!-- Title -->
    <div class="container">
      <div class="hero-title">
        <h4>Menu</h4>
        <small>Browse delicious items</small>
      </div>

      <!-- Main white panel -->
      <div class="panel" style="max-width: 980px; margin: 0 auto;">
        <div class="panel-top">
          <div class="left-actions">
            <a href="/trucks" class="btn btn-default btn-sm">← Back to Trucks</a>
          </div>
          <div class="right-actions">
            <div class="searchbar" style="flex-grow: 1; max-width: 420px;">
              <input id="searchInput" class="form-control form-control-sm" type="text" placeholder="Search a category..." />
            </div>
            <button id="filterBtn" class="btn btn-brand btn-sm" type="button">FILTER</button>
            <button id="clearBtn" class="btn btn-default btn-sm" type="button">Clear</button>
          </div>
        </div>

        <!-- Success/Error Messages -->
        <div id="successMessage" class="alert alert-success"></div>
        <div id="menuError" class="alert alert-danger"></div>

        <!-- Grid -->
        <div class="row" id="menuGrid">
          <!-- Menu items will be injected here by truckMenu.js -->
        </div>

        <div id="noItemsMessage" class="text-center text-muted" style="display:none; padding: 30px;">
          No menu items available for this truck.
        </div>
      </div>
    </div>

    <script src="/js/jquery-2.2.0.min.js" type="text/javascript"></script>
    <script src="/js/bootstrap.min.js" type="text/javascript"></script>
    <script src="/src/truckMenu.js" type="text/javascript"></script>
  </body>
</html>

