<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>GIU Food Truck – Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/style.css" />
  </head>
  <body class="min-vh-100"
        style="background: linear-gradient(135deg, #6a7bd1, #7a4db6);">
    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark px-4">
      <a class="navbar-brand fw-semibold" href="/dashboard">🍔 GIU Food Truck</a>
      <ul class="navbar-nav flex-row gap-4 ms-4">
        <li class="nav-item">
          <a class="nav-link active" href="/trucks">🚚 Trucks</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/cart">🛒 Cart</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/orders">📦 My Orders</a>
        </li>
      </ul>
      <div class="ms-auto">
        <a href="/logout" class="nav-link text-light">Logout</a>
      </div>
    </nav>

    <!-- Content -->
    <div class="container my-5">
      <!-- Welcome Banner -->
      <div class="rounded-4 text-center text-white p-5 mb-5"
           style="background: linear-gradient(135deg, #ff7a3d, #ff935f);">
        <div class="fs-3 mb-2">👋</div>
        <h3 class="fw-bold">Welcome back, {{ name }}!</h3>
        <p class="mb-0 opacity-75">
          Order delicious food from the best trucks on campus
        </p>
      </div>

      <!-- Cards Row -->
      <div class="row g-4">
        <!-- Quick Actions -->
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body p-4">
              <h6 class="fw-bold mb-3">🚀 Quick Actions</h6>
              <a href="/trucks" class="btn btn-warning w-100 mb-2 fw-semibold">
                🚚 BROWSE FOOD TRUCKS
              </a>
              <a href="/cart" class="btn btn-outline-secondary w-100 mb-2">
                🛒 View Cart
              </a>
              <a href="/orders" class="btn btn-outline-secondary w-100">
                📦 My Orders
              </a>
            </div>
          </div>
        </div>

        <!-- How It Works -->
        <div class="col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body p-4">
              <h6 class="fw-bold mb-3">📘 How It Works</h6>
              <ol class="mb-0 text-muted">
                <li>Browse available food trucks</li>
                <li>Select items from the menu</li>
                <li>Add items to your cart</li>
                <li>Schedule your pickup time</li>
                <li>Enjoy your delicious food!</li>
              </ol>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
