<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>GIU Food Truck - Register</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="/js/jquery-2.2.0.min.js" type="text/javascript"></script>
    <script src="/src/register.js" type="text/javascript"></script>
  </head>
  <body class="min-vh-100 d-flex flex-column"
        style="background: linear-gradient(135deg, #6a7bd1, #7a4db6);">
    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark px-4">
      <a class="navbar-brand fw-semibold" href="/">🍔 GIU Food Truck</a>
      <div class="ms-auto">
        <a href="/" class="btn btn-sm btn-outline-light me-2">Login</a>
        <a href="/register" class="btn btn-sm btn-warning">Register</a>
      </div>
    </nav>

    <!-- Centered Register Card -->
    <div class="container flex-grow-1 d-flex align-items-center justify-content-center py-4">
      <div class="card shadow-lg border-0" style="max-width: 420px; width: 100%;">
        <div class="card-body p-4 text-center">
          <div class="fs-2 mb-2">🍔</div>
          <h4 class="fw-bold">Create Account</h4>
          <p class="text-muted mb-4">Join now and start ordering from your favorite food trucks</p>

          <div id="registerError" class="alert alert-danger" style="display:none;"></div>

          <form id="registerForm" autocomplete="off">
            <div class="mb-3 text-start">
              <label for="name" class="form-label">Full Name</label>
              <input
                type="text"
                class="form-control"
                id="name"
                name="name"
                placeholder="Enter your full name"
                required
              />
            </div>

            <div class="mb-3 text-start">
              <label for="date" class="form-label">Birth Date</label>
              <input
                type="date"
                class="form-control"
                id="date"
                name="date"
                required
              />
            </div>

            <div class="mb-3 text-start">
              <label for="email" class="form-label">Email Address</label>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                placeholder="Enter your email"
                required
              />
            </div>

            <div class="mb-3 text-start">
              <label for="password" class="form-label">Password</label>
              <input
                type="password"
                class="form-control"
                id="password"
                name="password"
                placeholder="Create a password"
                required
              />
            </div>

            <button id="register" name="register" type="button" class="btn btn-warning w-100 fw-semibold">
              REGISTER
            </button>
          </form>

          <p class="mt-3 mb-0 text-muted">
            Already have an account?
            <a href="/" class="text-warning fw-semibold text-decoration-none">
              Login here
            </a>
          </p>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
