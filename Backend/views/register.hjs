<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>GIU Food Truck - Register</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/styles/bootstrap.min.css" />
  <link rel="stylesheet" href="/styles/style.css" />
  <script src="/js/jquery-2.2.0.min.js" type="text/javascript"></script>
  <script src="/src/register.js" type="text/javascript"></script>
  <style>
    .register-page {
      min-height: 100vh;
      background: linear-gradient(135deg, #6a7bd1, #7a4db6);
    }

    .register-navbar {
      background-color: #1f2a3b !important;
      border-radius: 0;
      margin-bottom: 0;
      border: none;
    }

    .register-navbar .navbar-brand {
      color: #fff !important;
      font-weight: 600;
    }

    .register-container {
      min-height: calc(100vh - 51px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 15px;
    }

    .register-card {
      background: #ffffff;
      border-radius: 12px;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
      max-width: 420px;
      width: 100%;
      padding: 40px 35px;
    }

    .register-icon {
      font-size: 48px;
      text-align: center;
      margin-bottom: 15px;
    }

    .register-title {
      font-size: 28px;
      font-weight: 700;
      text-align: center;
      margin-bottom: 8px;
      color: #333;
    }

    .register-subtitle {
      text-align: center;
      color: #777;
      margin-bottom: 30px;
      font-size: 14px;
    }

    .register-footer {
      text-align: center;
      margin-top: 20px;
      color: #666;
      font-size: 14px;
    }

    .register-footer a {
      color: #ffc107;
      font-weight: 600;
      text-decoration: none;
    }

    .register-footer a:hover {
      text-decoration: underline;
    }

    .navbar-right-btns {
      float: right;
      margin-top: 8px;
    }

    .navbar-right-btns .btn {
      margin-left: 8px;
    }
  </style>
</head>

<body class="register-page">
  <!-- Navbar -->
  <nav class="navbar navbar-inverse register-navbar">
    <div class="container-fluid">
      <div class="navbar-header">
        <a class="navbar-brand" href="/">🍔 GIU Food Truck</a>
      </div>
      <div class="navbar-right-btns">
        <a href="/" class="btn btn-default btn-sm">Login</a>
        <a href="/register" class="btn btn-warning btn-sm">Register</a>
      </div>
    </div>
  </nav>

  <!-- Register Card -->
  <div class="register-container">
    <div class="register-card">
      <div class="register-icon">🍔</div>
      <h1 class="register-title">Create Account</h1>
      <p class="register-subtitle">Join now and start ordering from your favorite food trucks</p>

      <div id="registerError" class="alert alert-danger" style="display:none;"></div>

      <form id="registerForm" autocomplete="off">
        <div class="form-group">
          <label for="name">Full Name</label>
          <input type="text" class="form-control" id="name" name="name" placeholder="Enter your full name" required />
        </div>

        <div class="form-group">
          <label for="date">Birth Date</label>
          <input type="date" class="form-control" id="date" name="date" required />
        </div>

        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" class="form-control" id="email" name="email" placeholder="Enter your email" required />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" class="form-control" id="password" name="password" placeholder="Create a password"
            required />
        </div>

        <button id="register" name="register" type="button" class="btn btn-warning btn-block btn-lg"
          style="font-weight: 600;">
          REGISTER
        </button>
      </form>

      <p class="register-footer">
        Already have an account?
        <a href="/">Login here</a>
      </p>
    </div>
  </div>

  <script src="/js/bootstrap.min.js" type="text/javascript"></script>
</body>

</html>