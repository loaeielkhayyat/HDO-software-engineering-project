<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>GIU Food Truck - Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Bootstrap CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="/js/jquery-2.2.0.min.js" type="text/javascript"></script>
    <script src="/src/login.js" type="text/javascript"></script>
  </head>
  <body class="min-vh-100 d-flex flex-column"
        style="background: linear-gradient(135deg, #6a7bd1, #7a4db6);">
    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark px-4">
      <a class="navbar-brand fw-semibold" href="/">🍔 GIU Food Truck</a>
      <div class="ms-auto">
        <a href="/" class="btn btn-sm btn-warning me-2">Login</a>
        <a href="/register" class="btn btn-sm btn-outline-light">Register</a>
      </div>
    </nav>

    <!-- Centered Login Card -->
    <div class="container flex-grow-1 d-flex align-items-center justify-content-center">
      <div class="card shadow-lg border-0" style="max-width: 420px; width: 100%;">
        <div class="card-body p-4 text-center">
          <div class="fs-2 mb-2">🍔</div>
          <h4 class="fw-bold">Welcome Back!</h4>
          <p class="text-muted mb-4">Sign in to order delicious food</p>

          <div id="loginError" class="alert alert-danger" style="display:none;"></div>

          <form id="loginForm" autocomplete="off">
            <div class="mb-3 text-start">
              <label for="email" class="form-label">Email Address</label>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                placeholder="Enter your email"
                required
              />
            </div>

            <div class="mb-3 text-start">
              <label for="password" class="form-label">Password</label>
              <input
                type="password"
                class="form-control"
                id="password"
                name="password"
                placeholder="Enter your password"
                required
              />
            </div>

            <button id="submit" name="submit" type="button" class="btn btn-warning w-200 fw-semibold">
              SIGN IN
            </button>
          </form>

          <p class="mt-3 mb-0 text-muted">
            Don't have an account?
            <a href="/register" class="text-warning fw-semibold text-decoration-none">
              Register here
            </a>
          </p>
        </div>
      </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
