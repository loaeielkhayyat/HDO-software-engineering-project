<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>GIU Food Truck - Login</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="/styles/bootstrap.min.css" />
  <link rel="stylesheet" href="/styles/style.css" />
  <script src="/js/jquery-2.2.0.min.js" type="text/javascript"></script>
  <script src="/src/login.js" type="text/javascript"></script>
  <style>
    .login-page {
      min-height: 100vh;
      background: linear-gradient(135deg, #6a7bd1, #7a4db6);
    }

    .login-navbar {
      background-color: #1f2a3b !important;
      border-radius: 0;
      margin-bottom: 0;
      border: none;
    }

    .login-navbar .navbar-brand {
      color: #fff !important;
      font-weight: 600;
    }

    .login-container {
      min-height: calc(100vh - 51px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 15px;
    }

    .login-card {
      background: #ffffff;
      border-radius: 12px;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.25);
      max-width: 420px;
      width: 100%;
      padding: 40px 35px;
    }

    .login-icon {
      font-size: 48px;
      text-align: center;
      margin-bottom: 15px;
    }

    .login-title {
      font-size: 28px;
      font-weight: 700;
      text-align: center;
      margin-bottom: 8px;
      color: #333;
    }

    .login-subtitle {
      text-align: center;
      color: #777;
      margin-bottom: 30px;
      font-size: 14px;
    }

    .login-footer {
      text-align: center;
      margin-top: 20px;
      color: #666;
      font-size: 14px;
    }

    .login-footer a {
      color: #ffc107;
      font-weight: 600;
      text-decoration: none;
    }

    .login-footer a:hover {
      text-decoration: underline;
    }

    .navbar-right-btns {
      float: right;
      margin-top: 8px;
    }

    .navbar-right-btns .btn {
      margin-left: 8px;
    }
  </style>
</head>

<body class="login-page">
  <!-- Navbar -->
  <nav class="navbar navbar-inverse login-navbar">
    <div class="container-fluid">
      <div class="navbar-header">
        <a class="navbar-brand" href="/">🍔 GIU Food Truck</a>
      </div>
      <div class="navbar-right-btns">
        <a href="/" class="btn btn-warning btn-sm">Login</a>
        <a href="/register" class="btn btn-default btn-sm">Register</a>
      </div>
    </div>
  </nav>

  <!-- Login Card -->
  <div class="login-container">
    <div class="login-card">
      <div class="login-icon">🍔</div>
      <h1 class="login-title">Welcome Back!</h1>
      <p class="login-subtitle">Sign in to order delicious food</p>

      <div id="loginError" class="alert alert-danger" style="display:none;"></div>

      <form id="loginForm" autocomplete="off">
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" class="form-control" id="email" name="email" placeholder="Enter your email" required />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" class="form-control" id="password" name="password" placeholder="Enter your password"
            required />
        </div>

        <button id="submit" name="submit" type="button" class="btn btn-warning btn-block btn-lg"
          style="font-weight: 600;">
          SIGN IN
        </button>
      </form>

      <p class="login-footer">
        Don't have an account?
        <a href="/register">Register here</a>
      </p>
    </div>
  </div>

  <script src="/js/bootstrap.min.js" type="text/javascript"></script>
</body>

</html>